# Windows batch files must always use CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Text files use LF
*.py    text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.ini   text eol=lf
*.toml  text eol=lf

# Binary files
*.zip   binary
*.png   binary
*.jpg   binary
*.ico   binary
